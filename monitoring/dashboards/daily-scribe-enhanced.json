      "pluginVersion": "10.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - daily_scribe_cronjob_last_success_timestamp",
          "legendFormat": "{{cronjob}}",
          "refId": "A"
        }
      ],
      "title": "Time Since Last Successful Run",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
