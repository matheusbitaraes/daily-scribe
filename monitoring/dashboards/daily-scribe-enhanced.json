      "title": "Cronjob Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "How long since each cronjob last completed successfully. Green < 2h, yellow < 8h, red > 8h.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7200 },
              { "color": "red", "value": 28800 }
            ]
          },
          "unit": "s",
          "noValue": "No data yet"
