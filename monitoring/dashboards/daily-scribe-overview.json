      },
      "pluginVersion": "10.1.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (cronjob) (count_over_time({job=\"cronlogs\", level=\"ERROR\"}[$__range]))",
          "instant": true,
          "legendFormat": "{{cronjob}}",
          "refId": "A"
        }
      ],
      "title": "Cron Errors by Job",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "valueLabel": "cronjob" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "Errors", "cronjob": "Job" }
          }
        }
      ],
      "type": "table"
    },
